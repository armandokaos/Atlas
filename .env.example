# ── X (Twitter) API ──────────────────────────────────────────────────────────
# Bearer Token from https://developer.x.com
# Free tier is enough: 15 req/15 min, batches of 100 users, ~4 calls total.
X_BEARER_TOKEN=your_x_bearer_token_here

# ── GitHub API ────────────────────────────────────────────────────────────────
# Personal access token from https://github.com/settings/tokens
# No special permissions needed (public data only). Raises rate limit to 5,000 req/hour.
GITHUB_TOKEN=your_github_token_here

# ── Proxycurl (LinkedIn) ──────────────────────────────────────────────────────
# API key from https://proxycurl.com
# 1 credit per profile (~$0.01). 135 LinkedIn profiles ≈ $1.35 total.
# Pass use_cache=if-present to avoid re-charging for recently fetched profiles.
PROXYCURL_API_KEY=your_proxycurl_api_key_here
